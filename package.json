{
  "name": "pmdd-tracker",
  "version": "1.1.1",
  "description": "Discord bot for tracking PMDD symptoms",
  "main": "dist/entry/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/entry/index.js",
    "dev": "tsc && node dist/entry/index.js",
    "deploy-commands": "tsc && node dist/entry/deploy-commands.js",
    "seed": "tsc && node dist/entry/seed-database.js",
    "seed-questionset": "tsc && node dist/entry/seed-questionSet.js",
    "watch": "tsc --watch"
  },
  "keywords": [
    "discord",
    "bot",
    "pmdd",
    "health"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "csv-parser": "^3.0.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.5",
    "typescript": "^5.3.3"
  }
}
